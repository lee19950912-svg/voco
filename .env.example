# 复制这个文件成 .env，然后填入 Key（不要加引号）
# .env 不要提交到 git

# 中转站（柏拉图 bltcy.ai）：用于翻译（gpt-4.1-mini）
# 注册：https://api.bltcy.ai/
RELAY_API_KEY=

# DeepSeek 官方：用于润色（deepseek-v4-pro 折扣期 / deepseek-v4-flash 长期）
# 注册：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenAI 官方：备用（韩国用户可直连）
OPENAI_API_KEY=

# 火山引擎一句话识别（中国主市场 ASR）
# 注册：https://www.volcengine.com/  →  控制台「语音识别」
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_CLUSTER_ZH=volcengine_input_common
VOLC_CLUSTER_KO=volcengine_input_ko_kr
