# 复制这个文件成 .env，然后填入自己的 Key（不要加引号）
# .env 不会提交到 git —— 每个人用自己的密钥

# ── 语音识别（ASR）──────────────────────────────
# 火山引擎「一句话识别」（中国大陆直连，中文最准）
# 注册：https://www.volcengine.com/  →  控制台「语音识别」
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
# 下面两个有默认值，一般不用改
VOLC_CLUSTER_ZH=volcengine_input_common
VOLC_CLUSTER_KO=volcengine_input_ko_kr

# ── AI 润色 / 翻译 ──────────────────────────────
# DeepSeek 官方：用于润色
# 注册：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 中转站：用于翻译
RELAY_API_KEY=

# OpenAI 官方：备用
OPENAI_API_KEY=

# ── 海外线路（可选，中国大陆用户可留空）─────────────
# 海外中转 ASR 用的 Key
OVERSEAS_API_KEY=
# 海外中转 润色/翻译 用的 Key；留空则复用上面的 OVERSEAS_API_KEY
OVERSEAS_CHAT_API_KEY=
