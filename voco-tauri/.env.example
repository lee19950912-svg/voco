# Copy this file to .env and fill in your own key (no quotes).
# .env is git-ignored — everyone uses their own key.
#
# NOTE: VoCo now reads keys from the app first (Settings → AI service).
# This .env is only a fallback for people who prefer file-based config —
# it's used when the app has no key filled in.

# ── AI service (OpenAI-compatible, bring-your-own-key) ──────────
# API key for chat + speech-to-text. Any OpenAI-compatible provider works:
# OpenAI directly, a domestic relay, or a local model server.
# Used as a fallback when no key is set in the app.
OPENAI_API_KEY=
